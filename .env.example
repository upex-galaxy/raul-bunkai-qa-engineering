# ============================================================================
# KATA Architecture - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# Note: Bun loads .env automatically — no dotenv needed.
#
# Variables are validated at startup by validateEnv.ts.
# Only variables for current TEST_ENV are required.
# ============================================================================


# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================
# Which environment to test against
# Valid: local | staging
TEST_ENV=local


# ============================================================================
# TEST USER CREDENTIALS (Required per environment)
# ============================================================================
# Only credentials for your current TEST_ENV are validated.
# The other environment's credentials can be left empty.

# --- For TEST_ENV=local ---
LOCAL_USER_EMAIL=
LOCAL_USER_PASSWORD=

# --- For TEST_ENV=staging ---
STAGING_USER_EMAIL=
STAGING_USER_PASSWORD=


# ============================================================================
# BROWSER / RUNTIME (Optional overrides)
# ============================================================================
# HEADLESS=true
# DEFAULT_TIMEOUT=30000
# SCREENSHOT_ON_FAILURE=true
# VIDEO_ON_FAILURE=true
# ALLURE_RESULTS_DIR=./allure-results


# ----------------------------------------------------------------------------
#* AI AGENT MCP SERVERS — loading mechanics
# ----------------------------------------------------------------------------
# .mcp.json (Claude Code) and opencode.jsonc are committed to git and reference
# env vars via expansion:
#   - .mcp.json      → ${VAR_NAME} / ${VAR:-default}  (FAILS if missing)
#   - opencode.jsonc → {env:VAR_NAME}                 (empty string if missing)
#
# Two ways to load these vars before launching the agent:
#
#   A) Cross-platform wrapper (default, works on Windows/Mac/Linux):
#        bun run claude     → wraps `claude` with dotenv-cli
#        bun run opencode   → idem
#
#   B) Optional, Mac/Linux only: direnv auto-loads on `cd` into the repo.
#      See .envrc for the one-time setup. Once configured, run
#      `claude` / `opencode` directly — direnv exports .env into your shell.
# ----------------------------------------------------------------------------


# ============================================================================
# ATLASSIAN — single source of truth (DRY)
# ============================================================================
# One family of vars covers EVERY Atlassian consumer in this repo:
#   - acli CLI (skill .claude/skills/acli)
#   - xray-cli (skill .claude/skills/xray-cli)
#   - scripts/sync-jira-*.ts (raw REST calls)
#   - cli/doctor.ts auth loop
#   - Jira-Direct TMS provider (config/variables.ts → config.tms.jira)
#   - (opt-in) MCP atlassian server — see docs/mcp/ to enable it manually
#
# Naming rule:
#   - ATLASSIAN_*  = credentials
#   - JIRA_*       = operational (project key, output dir, custom field, etc.)
#
# Get an API token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# --- Jira operational params (NOT credentials) ---
# Default project key for `bun run jira:sync-issues` (else .agents/project.yaml).
# JIRA_PROJECT_KEY=
# Output directory for synced issues (default: .context/PBI).
# JIRA_SYNC_OUTPUT=
# Default sprint selector for `pull --sprint` (active | current | closed | >=N | 7,8,10).
# Flag --sprint overrides this; this overrides the no-filter default.
# JIRA_SYNC_SPRINTS=
# Default csv of optional coverable work-type slugs added to `pull` (e.g. improvement,tech-story,tech-debt).
# Flag --types overrides this; this overrides the default scope (Epics + Stories + Bugs).
# JIRA_SYNC_TYPES=
# Jira-Direct TMS provider — custom field for run status:
# JIRA_TEST_STATUS_FIELD=customfield_10100


# ============================================================================
# TMS — Xray Cloud (Optional, also CI secrets)
# ============================================================================
# TMS_PROVIDER=xray
#
# The four vars below are active CI secrets referenced by .github/workflows/
# regression.yml (lines 45-47). They are pushed to GitHub Actions by
# `bun run setup --variables` and read back here for local runs. Leave them
# empty unless you actually use Xray sync — they are only required when
# TMS_PROVIDER=xray AND AUTO_SYNC=true.

# Operational flag — set true to auto-sync results to Xray in CI.
AUTO_SYNC=false
# Xray Cloud API credentials (https://app.getxray.app → API Keys).
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
# Xray project key to sync against.
XRAY_PROJECT_KEY=


# ============================================================================
# SEARCH / DOCS MCPs
# ============================================================================
# Tavily — web search MCP — https://app.tavily.com/
TAVILY_API_KEY=


# ============================================================================
# API EXPLORATION MCPs
# ============================================================================
# OpenAPI MCP — backend API contract exploration
API_BASE_URL=
OPENAPI_SPEC_PATH=
# Auto-populated by `bun run api:login` (rewrites this line in your local .env).
# After login, RESTART your terminal so MCP servers pick up the new value.
API_TOKEN=

# Postman MCP — collection runner
# Get key: https://postman.com → workspace → API keys
POSTMAN_API_KEY=


# ============================================================================
# RESEND — Email-based test verification (Optional)
# ============================================================================
# Get a key: https://resend.com/api-keys
# Docs: https://resend.com/docs/api-reference/introduction
# Used for email-flow tests (signup confirmation, password reset, magic links).
# Also authenticates the `resend` CLI (CLI alt: `resend login` via browser).
RESEND_API_KEY=


# ============================================================================
# DBHUB MCP — DATABASE CONNECTION (Optional, manual setup)
# ============================================================================
# NOT managed by the installer or `bun run doctor` — you must edit `dbhub.toml`
# yourself based on the target project's database. The installer cannot know
# which DB (sqlserver/postgres/mysql/sqlite/mariadb) your project uses.
#
# Required only when the DBHub MCP server is enabled (.mcp.json → "dbhub").
# These vars are interpolated into the tracked file `dbhub.toml` at the repo
# root (the file uses `${VAR}` placeholders — safe to commit, no secrets in
# the TOML itself).
#
# IMPORTANT CAVEAT: DBHub silently substitutes the literal string `${VAR}`
# when a variable is missing from the process environment. This produces a
# cryptic auth failure (not a startup error). Verify all DBHUB_* vars below
# are exported BEFORE launching the MCP server: `env | grep DBHUB`.
#
# Add additional [[sources]] blocks in dbhub.toml if you need more databases.
DBHUB_TYPE=          # sqlserver | postgres | mysql | sqlite | mariadb
DBHUB_HOST=
DBHUB_PORT=          # 1433 (sqlserver) | 5432 (postgres) | 3306 (mysql/mariadb)
DBHUB_DATABASE=
DBHUB_USER=
DBHUB_PASSWORD=


# ============================================================================
# CI-ONLY SECRETS (set in GitHub Actions, NOT needed for local runs)
# ============================================================================
# Pushed to GitHub Actions by `bun run setup --variables`. Optional; only the
# CI workflows consume them, so they stay commented in your local .env.
#
# Slack incoming webhook for CI test-result notifications.
# SLACK_WEBHOOK_URL=


# ----------------------------------------------------------------------------
# CI/CD VARIABLES (set automatically by the runner, NOT here)
# ----------------------------------------------------------------------------
# CI=true          (set by GitHub Actions)
# BUILD_ID=<id>    (set by GitHub Actions)
# ----------------------------------------------------------------------------
