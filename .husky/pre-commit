bunx lint-staged

# Light-weight repo health checks on every commit (fast, cover full repo).
bun run types:check
bun run vars:check
bun run skills:check

# kata-manifest freshness gate — only runs when staged files affect it.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if echo "$STAGED" | grep -qE '^(tests/components/|scripts/kata-manifest\.ts$|kata-manifest\.json$)'; then
  bun run kata:manifest:check || {
    echo ""
    echo "❌ kata-manifest.json is stale. Fix:"
    echo "   bun run kata:manifest && git add kata-manifest.json"
    exit 1
  }
fi

# skill-registry freshness gate — only runs when staged files affect it.
if echo "$STAGED" | grep -qE '^(\.claude/skills/.+/SKILL\.md$|scripts/build-skill-registry\.ts$|\.claude/skills/REGISTRY\.md$)'; then
  bun run skills:registry:check || {
    echo ""
    echo "❌ .claude/skills/REGISTRY.md is stale. Fix:"
    echo "   bun run skills:registry && git add .claude/skills/REGISTRY.md"
    exit 1
  }
fi
