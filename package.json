{
  "name": "raul-bunkai-qa-engineering",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "author": "UPEX Galaxy",
  "license": "MIT",
  "homepage": "https://github.com/upex-galaxy/agentic-qa-boilerplate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/upex-galaxy/agentic-qa-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/upex-galaxy/agentic-qa-boilerplate/issues"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "integration",
    "kata",
    "automation",
    "bun",
    "typescript",
    "boilerplate",
    "ai-driven",
    "agent-skills",
    "agentskills",
    "claude-code",
    "quality-engineering",
    "shift-left-testing",
    "agentic"
  ],
  "scripts": {
    "agents:setup": "bun scripts/agents-setup.ts",
    "allure:agent": "bunx allure agent -- bun test",
    "allure:generate": "bunx allure generate ./allure-results",
    "allure:open": "bunx allure open",
    "allure:run": "bunx allure run -- bun test",
    "allure:watch": "bunx allure watch ./allure-results",
    "api:login:local": "bun scripts/api-login.ts local",
    "api:login:staging": "bun scripts/api-login.ts staging",
    "api:login": "bun scripts/api-login.ts",
    "api:sync": "bun scripts/sync-openapi.ts",
    "claude": "bash -c 'set -a; . ./.env; set +a; exec claude \"$@\"' --",
    "env": "set -a; source .env; set +a",
    "format:check": "prettier --check '**/*.{json,yml,yaml,css,scss,html}' --ignore-path .prettierignore",
    "format:fix": "prettier --write '**/*.{json,yml,yaml,css,scss,html}' --ignore-path .prettierignore",
    "jira:check": "bun scripts/check-jira-setup.ts",
    "jira:sync-fields": "bun scripts/sync-jira-fields.ts",
    "jira:sync-issues": "bun scripts/sync-jira-issues.ts",
    "jira:sync-link-types": "bun scripts/sync-jira-link-types.ts",
    "jira:sync-workflows": "bun scripts/sync-jira-workflows.ts",
    "kata:manifest:check": "bun scripts/kata-manifest.ts --check",
    "kata:manifest:watch": "bun scripts/kata-manifest.ts --watch",
    "kata:manifest": "bun scripts/kata-manifest.ts",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "onboarding": "bun scripts/onboarding.ts",
    "opencode": "bash -c 'set -a; . ./.env; set +a; exec opencode \"$@\"' --",
    "prepare": "husky",
    "pw:install": "playwright install --with-deps chromium",
    "repo:check": "bun run format:check && bun run lint:check && bun run types:check && bun run vars:check && bun run skills:check && bun run skills:registry:check && bun run vars:env:check",
    "repo:fix": "bun run format:fix && bun run lint:fix && bun run types:check && bun run vars:check && bun run skills:check && bun run skills:registry:check && bun run vars:env:check",
    "setup:doctor": "bun cli/doctor.ts",
    "setup": "bun cli/doctor.ts --preflight && bun cli/install.ts",
    "skills:check": "bun scripts/lint-skills.ts",
    "skills:registry:check": "bun scripts/build-skill-registry.ts --check",
    "skills:registry": "bun scripts/build-skill-registry.ts",
    "test:clean": "rm -rf test-results playwright-report allure-results allure-report reports",
    "test:debug": "playwright test --debug",
    "test:e2e": "playwright test --project=e2e",
    "test:env:check": "bun config/validateTestEnv.ts",
    "test:headed": "playwright test --headed",
    "test:integration": "playwright test --project=integration",
    "test:last-failed": "playwright test --last-failed",
    "test:report": "playwright show-report",
    "test:retries": "playwright test --retries=2",
    "test:smoke": "playwright test --project=smoke",
    "test:sync": "bun tests/utils/jiraSync.ts",
    "test:ui": "playwright test --ui",
    "test": "playwright test",
    "types:check": "tsc --noEmit",
    "up": "bun cli/update-boilerplate.ts",
    "vars:check": "bun scripts/lint-vars.ts",
    "vars:env:check": "bun scripts/check-vars.ts",
    "xray": "bun cli/xray/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@inquirer/prompts": "^8.1.0",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "figures": "^6.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.0",
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.7",
    "@types/node": "^24.10.1",
    "allure": "^3.8.2",
    "allure-playwright": "^3.8.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.7.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,yml,yaml,css,scss,html}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  }
}
