# ===========================================
# Documentation - Preserve manual formatting
# ===========================================
.context/
.claude/skills/
.claude/settings.local.json
.agents/skills/

# ===========================================
# MCP reference templates - never format
# ===========================================
# docs/mcp/*.template.* are syntax-sensitive opt-in configs (claude / opencode /
# gemini / codex) that users copy verbatim into their active MCP config. Prettier
# normalizes whitespace and trailing commas that would break the copy-paste path.
docs/mcp/

# ===========================================
# Installer state - regenerated by bun run setup
# ===========================================
# .template/installer.state.json is regenerated between every installer step,
# so prettier --check races against the writes. Skip the whole dir.
.template/

# ===========================================
# Runtime session artifacts - generated, gitignored
# ===========================================
# Saved auth state and Playwright session output are regenerated every QA run
# and are already gitignored. Prettier honors only .prettierignore (not
# .gitignore), so without these globs format:check fails on transient output.
# .playwright/cli.config.json is tracked config — keep it formatted (negated).
# .playwright-mcp/page-*.yml are transient page snapshots emitted by the
# Playwright MCP server on every browser navigation — same gitignore/Prettier gap.
.auth/
.playwright/
!.playwright/cli.config.json
.playwright-mcp/

# ===========================================
# Xray backup artifacts - generated, gitignored
# ===========================================
# `bun xray backup export` writes JSON dumps and `restore` writes key-mapping
# CSVs into .backups/ (gitignored). They are machine-generated data, not
# hand-authored source — Prettier must skip them or format:check fails on them.
.backups/

# ===========================================
# Git worktrees - another branch's checkout, not this tree
# ===========================================
# A git worktree placed under .claude/worktrees/ is a separate branch's full
# checkout. Prettier (which honors only .prettierignore, not .git metadata)
# would otherwise recurse into it and flag formatting on files we don't own here.
.claude/worktrees/
