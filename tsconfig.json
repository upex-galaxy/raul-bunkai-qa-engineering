{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"],
      "@ui/*": ["./tests/components/ui/*"],
      "@api/*": ["./tests/components/api/*"],
      "@steps/*": ["./tests/components/steps/*"],
      "@utils/*": ["./tests/utils/*"],
      "@data/*": ["./tests/data/*"],
      "@variables": ["./config/variables.ts"],
      "@TestContext": ["./tests/components/TestContext.ts"],
      "@UiFixture": ["./tests/components/UiFixture.ts"],
      "@ApiFixture": ["./tests/components/ApiFixture.ts"],
      "@TestFixture": ["./tests/components/TestFixture.ts"],
      "@DataFactory": ["./tests/data/DataFactory.ts"],
      "@openapi": ["./api/openapi-types.ts"],
      "@schemas/*": ["./api/schemas/*"],
      "@schemas": ["./api/schemas/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["bun", "node", "@playwright/test"],
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": [
    "config/**/*.ts",
    "tests/**/*.ts",
    "api/**/*.ts",
    "scripts/**/*.ts",
    "cli/**/*.ts",
    "packages/**/*.ts",
    "playwright.config.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules",
    "packages/*/dist",
    "playwright-report",
    "test-results",
    "allure-results",
    "allure-report",
    "reports"
  ]
}
